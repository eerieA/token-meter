# =========================
# Rust (root crate)
# =========================

/target/
**/*.rs.bk

# Keep Cargo.lock for applications (recommended)
# If this were a library, we would ignore it.
# !Cargo.lock

# =========================
# Tauri (src-tauri)
# =========================

/src-tauri/target/
/src-tauri/.cargo/
#/src-tauri/Cargo.lock   # Keep for apps (recommended)

# Tauri build outputs (bundles)
/src-tauri/gen/
/src-tauri/bundle/
/src-tauri/target/debug/
/src-tauri/target/release/

# Windows build artifacts
*.pdb
*.exe
*.msi

# =========================
# Node / Frontend
# =========================

/node_modules/
/dist/
/build/

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Keep package-lock.json for apps (recommended)
# !package-lock.json

# =========================
# Environment files
# =========================

.env
.env.local
.env.*.local

# =========================
# Editor / IDE
# =========================

.vscode/
.idea/
*.swp
*.swo
*~

# =========================
# OS generated
# =========================

.DS_Store
Thumbs.db
desktop.ini

# =========================
# Flycheck
# =========================

/flycheck0/

# =========================
# Logs
# =========================

*.log

# =========================
# Misc
# =========================

coverage/
